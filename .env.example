# EmailJS credentials — copy this file to .env and fill in your values.
# Sign up at https://www.emailjs.com/ (free tier works fine).
#
# 1. Add a service (connect your Gmail account).
# 2. Create an email template. In the template body use variables like:
#      From: {{from_name}} <{{from_email}}>
#      Message: New subscriber!  Name: {{from_name}}  Email: {{from_email}}
# 3. Copy the Service ID, Template ID, and Public Key below.

VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxx
VITE_EMAILJS_PUBLIC_KEY=your_public_key

# Optional: override the default recipient (defaults to henryscomicshop@gmail.com)
VITE_RECIPIENT_EMAIL=henryscomicshop@gmail.com
